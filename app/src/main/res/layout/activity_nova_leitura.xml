<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:background="@color/surface" android:padding="12dp"
        android:elevation="4dp">
        <ImageButton android:id="@+id/btnVoltar"
            android:layout_width="36dp" android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_marginEnd="8dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Nova Leitura" android:textSize="15sp"
            android:textStyle="bold" android:textColor="@color/textPrimary" />
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="APARTAMENTO" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/textSecondary" android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <Spinner android:id="@+id/spinnerApartamento"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/bg_input"
                android:paddingStart="12dp" android:paddingEnd="12dp"
                android:layout_marginBottom="16dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="PERÍODO" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/textSecondary" android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">
                <Spinner android:id="@+id/spinnerMes" android:layout_width="0dp"
                    android:layout_height="48dp" android:layout_weight="1"
                    android:background="@drawable/bg_input"
                    android:paddingStart="12dp" android:paddingEnd="12dp"
                    android:layout_marginEnd="8dp" />
                <Spinner android:id="@+id/spinnerAno" android:layout_width="100dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input"
                    android:paddingStart="12dp" android:paddingEnd="12dp" />
            </LinearLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="CONSUMO" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/textSecondary" android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="⚡ Eletricidade (kWh)"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etValorLuz"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="numberDecimal" android:imeOptions="actionNext" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="🔥 Gás (m³)"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etValorGas"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="numberDecimal" android:imeOptions="actionDone" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout android:id="@+id/layoutAviso"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="12dp"
                android:background="@drawable/bg_aviso"
                android:layout_marginBottom="8dp"
                android:visibility="gone">
                <TextView android:id="@+id/tvAviso"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="@color/amberDark" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <Button android:id="@+id/btnSalvar"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:layout_margin="16dp"
        android:text="Salvar Leitura"
        android:textSize="14sp"
        android:backgroundTint="@color/primaryDark" />

</LinearLayout>